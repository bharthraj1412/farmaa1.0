# ============================================================
# Farmaa Backend – Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# ── Database ──────────────────────────────────────────────
# Supabase PostgreSQL connection string (Transaction pooler recommended)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ── Security ───────────────────────────────────────────────
# Long random string for JWT signing (min 32 chars)
SECRET_KEY=farmaa-super-secret-key-change-in-production-min-32-chars

# ── Environment ────────────────────────────────────────────
# Options: development | production
ENVIRONMENT=development

# ── Firebase / Google Auth ─────────────────────────────────
# Your Firebase project ID (found in Firebase Console > Project Settings)
FIREBASE_PROJECT_ID=farmaa-bdbe3

# Option A: Path to service account JSON key file (local development)
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# Option B: JSON string of service account credentials (Vercel/Render env vars)
# Paste the entire JSON content as a single-line string
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"farmaa-bdbe3",...}

# ── OpenRouter AI ──────────────────────────────────────────
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use (default: auto-selects best available)
OPENROUTER_MODEL=openrouter/auto

# OpenRouter API base URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Supabase (optional – for direct Supabase operations) ───
SUPABASE_URL=https://qhllzkyklmvvvqkpzhbj.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Razorpay (optional – backend verification) ─────────────
RAZORPAY_KEY_ID=rzp_test_SKmYp2ETrwBn0s
RAZORPAY_KEY_SECRET=VQIMyqA3HzFF04ljBmu4GBYO
